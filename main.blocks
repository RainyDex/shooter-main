id="2XMqsuuTCn!$x?re_[Td"><value name="img"><shadow type="background_image_picker" id="w)W/F_7cdpT.n=YQK$2f"><field name="img">assets.image`TalkingBoss`</field><data>{"commentRefs":[],"fieldData":{"img":"myImages.image10"}}</data></shadow></value><next><block type="story_set_page_pause_length" id="e8UXE#!%SYlpZ5w%cMY|"><value name="pagePauseMillis"><shadow type="timePicker" id=";m,kxt_Z,Q2KTpuC5M32"><field name="ms">2000</field></shadow></value><value name="finalPagePauseMillis"><shadow type="timePicker" id="z6+a#q.od@T7ZZzc2M+%"><field name="ms">5000</field></shadow></value><next><block type="arcade_story_print_character_text" id="1`l$Rz:}E+MA]r+ns]-?"><mutation xmlns="http://www.w3.org/1999/xhtml" _expanded="1" _input_init="true"></mutation><value name="text"><shadow type="text" id="5.zg`:.aTyd~;}~*1}pp"><field name="TEXT">You're here.</field></shadow></value><value name="label"><shadow type="text" id="~lNUv58wW3gWmSo_iI5c"><field name="TEXT">Boss</field></shadow></value><next><block type="arcade_story_print_character_text" id="ElxM,-*EO~%:qelsE^={"><mutation xmlns="http://www.w3.org/1999/xhtml" _expanded="1" _input_init="true"></mutation><value name="text"><shadow type="text" id="%~`oDL4hGF2?L;I}ev.D"><field name="TEXT">Good.</field></shadow></value><value name="label"><shadow type="text" id="vjD7$qFP!BF:b`31=@Y3"><field name="TEXT">Boss</field></shadow></value><next><block type="arcade_story_print_character_text" id="@h5K!7*a1zOWC_]{1#_M"><mutation xmlns="http://www.w3.org/1999/xhtml" _expanded="1" _input_init="true"></mutation><value name="text"><shadow type="text" id="opnr}`:uZTx47;PXb/Ig"><field name="TEXT">I'll get to the main point.</field></shadow></value><value name="label"><shadow type="text" id="I%zki;S,c!`0A|5V=?8a"><field name="TEXT">Boss</field></shadow></value><next><block type="arcade_story_print_character_text" id="mv`MI0m}=,a0He4#dzUI"><mutation xmlns="http://www.w3.org/1999/xhtml" _expanded="1" _input_init="true"></mutation><value name="text"><shadow type="text" id="9T5A7O~/ED)D0C.bo{z3"><field name="TEXT">I need you to use our new special tool for recycling.</field></shadow></value><value name="label"><shadow type="text" id="PAhT++G{hHi(N(1)!!Iz"><field name="TEXT">Boss</field></shadow></value><next><block type="arcade_story_print_character_text" id="+cqtPO+I~N;nK}gxWO+Y"><mutation xmlns="http://www.w3.org/1999/xhtml" _expanded="1" _input_init="true"></mutation><value name="text"><shadow type="text" id="ZuYGRWs*VTpP.(}hRC!X"><field name="TEXT">Don't ask questions if you wanna get paid.</field></shadow></value><value name="label"><shadow type="text" id="S8j?Vt,!6zS5EYSw[-73"><field name="TEXT">Boss</field></shadow></value><next><block type="arcade_story_show_player_choices" id="]@K]|b%?xaCLR$k;T=dj"><mutation xmlns="http://www.w3.org/1999/xhtml" _expanded="0" _input_init="true"></mutation><value name="choice1"><shadow type="text" id="%!?DJ%SRHuF[HLqO/S%Q"><field name="TEXT">Sure.</field></shadow></value><value name="choice2"><shadow type="text" id="6|;I+Jrn4RlZ)JrppiJ{"><field name="TEXT">You pay me?</field></shadow></value><value name="choice3"><shadow type="text" id="~O%/m:G0]V]#u+PT^V6)"><field name="TEXT"></field></shadow></value><value name="choice4"><shadow type="text" id="Ti*MO|nE$L-[o7^+dT9R"><field name="TEXT"></field></shadow></value><value name="choice5"><shadow type="text" id="lRPwPjTMz)t8;y|=[`WA"><field name="TEXT"></field></shadow></value><next><block type="controls_if" id="r4qRN$7bw27tXNQbiZMw"><value name="IF0"><shadow type="logic_boolean" id="AP1~/?(?qe_W17A9U}p*"><field name="BOOL">TRUE</field></shadow><block type="arcade_story_last_answer" id="hyRnoJ75u!uEzPtDM3-q"><value name="choice"><shadow type="text" id="(Wq(8]sEwuH}D`D8U$sz"><field name="TEXT">Sure</field></shadow></value></block></value><statement name="DO0"><block type="arcade_story_print_character_text" id="F]yaZ=$U=TRU8eOZ$K(S"><mutation xmlns="http://www.w3.org/1999/xhtml" _expanded="1" _input_init="true"></mutation><value name="text"><shadow type="text" id="6wqMevkM+nI%eIhB3~F^"><field name="TEXT">Don't dissapoint me</field></shadow></value><value name="label"><shadow type="text" id="(ZRhOy`ktm+0Vi0OpV4H"><field name="TEXT">Boss</field></shadow></value></block></statement><next><block type="controls_if" id="d7ac6A!8u$^I,(%n+C%}"><value name="IF0"><shadow type="logic_boolean" id="I6GIJ`+mEGeO.ZRWNViV"><field name="BOOL">TRUE</field></shadow><block type="arcade_story_last_answer" id="YuL%k1[ZNyy~yF(G^ynE"><value name="choice"><shadow type="text" id="|@s?`-!j[%Y9B`Ags$-,"><field name="TEXT">You pay me?</field></shadow></value></block></value><statement name="DO0"><block type="arcade_story_print_character_text" id="zT$m`2_GA[F|L0ywR{wo"><mutation xmlns="http://www.w3.org/1999/xhtml" _expanded="1" _input_init="true"></mutation><value name="text"><shadow type="text" id="m[j+n5k;h38,-;WI8%]V"><field name="TEXT">Get out.</field></shadow></value><value name="label"><shadow type="text" id="G-rWj#;wRybWI+TXZ8Q`"><field name="TEXT">Boss</field></shadow></value><next><block type="gamesetbackgroundimage" id="u3e9N,6OY`F+Np93Qd.f"><value name="img"><shadow type="background_image_picker" id="_S0zo3Y(?Z7#s,]1yQRJ"><field name="img">assets.image`FreedomEnding`</field><data>{"commentRefs":[],"fieldData":{"img":"myImages.image9"}}</data></shadow></value><next><block type="gameSplash" id="9;Y[h_n^BQ,0YQi(C{{i"><mutation xmlns="http://www.w3.org/1999/xhtml" _expanded="0" _input_init="true"></mutation><value name="title"><shadow type="text" id="i3-|T%o+gAY^WT%@/O{t"><field name="TEXT">You never got your last check.</field></shadow></value><value name="subtitle"><shadow type="text" id="F4m#F*jY,0?dpQ6*SGSy"><field name="TEXT"></field></shadow></value><next><block type="device_pause" id="n,}o39n/MCnT[*5.L{th"><value name="pause"><shadow type="timePicker" id="z*NeG!wX$W{uGAU.z^ff"><field name="ms">2000</field></shadow></value><next><block type="gameOver2" id="klH,Qo2aPUu1iA`fOA+p"><value name="win"><shadow type