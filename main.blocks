d></shadow></value><next><block type="arcade_story_print_character_text" id="fZ[BV|x^=Hq+/r=XyOF}"><mutation xmlns="http://www.w3.org/1999/xhtml" _expanded="1" _input_init="true"></mutation><value name="text"><shadow type="text" id="k`#y$bTj)UEF202/ps19"><field name="TEXT">I'll get to the main point.</field></shadow></value><value name="label"><shadow type="text" id="`ky=HD88_c*!xzOuy2au"><field name="TEXT">Boss</field></shadow></value><next><block type="arcade_story_print_character_text" id="NZ)Tuoc%}@.#4d^GPm^c"><mutation xmlns="http://www.w3.org/1999/xhtml" _expanded="1" _input_init="true"></mutation><value name="text"><shadow type="text" id="yjJI-6%I4URk7[}f_SPR"><field name="TEXT">I need you to use our new special tool for recycling.</field></shadow></value><value name="label"><shadow type="text" id="[n5v3Q@~3|]h@@tpdKf#"><field name="TEXT">Boss</field></shadow></value><next><block type="arcade_story_print_character_text" id="VjRP$WN:am9I7[:a^IGN"><mutation xmlns="http://www.w3.org/1999/xhtml" _expanded="1" _input_init="true"></mutation><value name="text"><shadow type="text" id="97DHZ7K}8u%q/kQMc;Hw"><field name="TEXT">Don't ask questions if you want to get paid.</field></shadow></value><value name="label"><shadow type="text" id="F[$bG7n#Er0PIbue@^lk"><field name="TEXT">Boss</field></shadow></value><next><block type="arcade_story_show_player_choices" id="Pz(LB957%YkD/,W7SO3["><mutation xmlns="http://www.w3.org/1999/xhtml" _expanded="0" _input_init="true"></mutation><value name="choice1"><shadow type="text" id="c^V,._aiXC^3CdZl#1)="><field name="TEXT">Sure.</field></shadow></value><value name="choice2"><shadow type="text" id="]mpDN`?/N$%p+S1[f,z%"><field name="TEXT">You pay me?</field></shadow></value><next><block type="controls_if" id="L~K[L1f+a+,Oq)Um,nG3"><value name="IF0"><shadow type="logic_boolean" id="djUMd{oZ)z43G^+ro$fn"><field name="BOOL">TRUE</field></shadow><block type="arcade_story_last_answer" id="TT`bS6fa,U_dGK_*=%F^"><value name="choice"><shadow type="text" id="F5=3]*H4Y)v{$)%r#.v{"><field name="TEXT">Sure.</field></shadow></value></block></value><statement name="DO0"><block type="arcade_story_print_character_text" id="}c$S)qisyqa/4?|A1Ui^"><mutation xmlns="http://www.w3.org/1999/xhtml" _expanded="1" _input_init="true"></mutation><value name="text"><shadow type="text" id=":VG]#LsnGrwH2?#Vf9[D"><field name="TEXT">Don't disappoint me.</field></shadow></value><value name="label"><shadow type="text" id="rrWY##*._(IU3crQK#b]"><field name="TEXT">Boss</field></shadow></value></block></statement><next><block type="controls_if" id=".xo$2.!:N##g)BJecONr"><value name="IF0"><shadow type="logic_boolean" id="sUQza)=TE;F!)eq94TKi"><field name="BOOL">TRUE</field></shadow><block type="arcade_story_last_answer" id="llZZ4ANqZsM$1`TK6f]X"><value name="choice"><shadow type="text" id="uJ5H^4%{dZ%7o7u{u={m"><field name="TEXT">You pay me?</field></shadow></value></block></value><statement name="DO0"><block type="arcade_story_print_character_text" id=",}_oKbtHIFno6MTE;Id{"><mutation xmlns="http://www.w3.org/1999/xhtml" _expanded="1" _input_init="true"></mutation><value name="text"><shadow type="text" id="h.ULG]C:3uId(w~j}qVb"><field name="TEXT">Get. Out.</field></shadow></value><value name="label"><shadow type="text" id="BI_,:_d^,1,h-!g;*_.x"><field name="TEXT">Boss</field></shadow></value><next><block type="gamesetbackgroundimage" id="OXCDc^~bRsq:`~wPt6V*"><value name="img"><shadow type="background_image_picker" id=";SyEp3pu:yIIW^P+!(oD"><field name="img">assets.image`FreedomEnding`</field><data>{"commentRefs":[],"fieldData":{"img":"myImages.image9"}}</data></shadow></value><next><block type="gameSplash" id="DB)zA:@PS=8k6apnA9.q"><mutation xmlns="http://www.w3.org/1999/xhtml" _expanded="0" _input_init="true"></mutation><value name="title"><shadow type="text" id="=.azG1mppnFqE0~EM1]L"><field name="TEXT">You never got any money.</field></shadow></value><next><block type="device_pause" id="_WQ-@{pn+pw+?+vYXVMh"><value name="pause"><s